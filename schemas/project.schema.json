{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eternl.io/schemas/project.schema.json",
  "title": "Project",
  "description": "Project registry entry with metadata and scripts",
  "type": "object",
  "required": ["label", "category"],
  "properties": {
    "label": {
      "type": "string",
      "description": "Display name of the project",
      "minLength": 1
    },
    "caption": {
      "type": "string",
      "description": "Short tagline"
    },
    "summary": {
      "type": "string",
      "description": "Brief summary"
    },
    "description": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "short": { "type": "string" }
          },
          "required": ["short"],
          "additionalProperties": false
        }
      ],
      "description": "Description (string or object with 'short' property)"
    },
    "category": {
      "type": "string",
      "description": "Main category",
      "enum": [
        "DEFI",
        "MARKETPLACE",
        "COLLECTION",
        "GAMING",
        "COMMUNITY",
        "TOKEN_DISTRIBUTION",
        "STABLECOIN",
        "MOBILE_NETWORK",
        "GENERIC",
        "SMART_WALLET",
        "LAYER_2",
        "BLOCKCHAIN",
        "NFT_MINTING_PLATFORM",
        "UNKNOWN"
      ]
    },
    "subCategory": {
      "type": "string",
      "description": "Sub-category",
      "enum": [
        "AMM_DEX",
        "ORDERBOOK_DEX",
        "HYBRID_DEX",
        "CONCENTRATED_LIQUIDITY_DEX",
        "LENDING_BORROWING",
        "NFT",
        "ORACLE",
        "WRAPPED_ASSETS",
        "DEX",
        "DEX_AGGREGATOR",
        "CHARITY",
        "STAKING",
        "PERPETUALS",
        "LAUNCHPAD",
        "MINING",
        "SYNTHETICS",
        "OPTION",
        "STEALTH_WALLET",
        "SMART_WALLET",
        "UNKNOWN"
      ]
    },
    "link": {
      "type": "object",
      "description": "Social and website links",
      "properties": {
        "website": { "type": "string", "format": "uri" },
        "documentation": { "type": "string", "format": "uri" },
        "x": { "type": "string", "format": "uri" },
        "discord": { "type": "string", "format": "uri" },
        "reddit": { "type": "string", "format": "uri" },
        "telegram": { "type": "string", "format": "uri" },
        "github": { "type": "string", "format": "uri" },
        "medium": { "type": "string", "format": "uri" },
        "forum": { "type": "string", "format": "uri" },
        "linkedin": { "type": "string", "format": "uri" },
        "youtube": { "type": "string", "format": "uri" },
        "facebook": { "type": "string", "format": "uri" },
        "linktree": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "branding": {
      "type": "object",
      "description": "Brand colors and icon for UI display",
      "properties": {
        "color": { "type": "string", "description": "Text color (hex)" },
        "bgColor": { "type": "string", "description": "Background color (hex)" },
        "icon": { "type": "string", "description": "Base64-encoded icon (data URI)" }
      },
      "required": ["color", "bgColor"],
      "additionalProperties": false
    },
    "scripts": {
      "type": "array",
      "description": "Script hashes and metadata",
      "items": {
        "type": "object",
        "required": ["name", "scriptHash"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable script name"
          },
          "scriptHash": {
            "type": "string",
            "description": "Script hash in hex format",
            "pattern": "^[a-fA-F0-9]+$",
            "minLength": 56
          },
          "purpose": {
            "type": "string",
            "description": "Script purpose (single or combined with /)",
            "pattern": "^(SPEND|MINT|MANAGE|WITHDRAW|PUBLISH|VOTE|STAKE)(/(SPEND|MINT|MANAGE|WITHDRAW|PUBLISH|VOTE|STAKE))*$"
          },
          "type": {
            "type": "string",
            "description": "Script type",
            "enum": ["PLUTUS", "NATIVE"]
          },
          "plutusVersion": {
            "type": "integer",
            "description": "Plutus version (1, 2, or 3)",
            "enum": [0, 1, 2, 3]
          }
        },
        "additionalProperties": false
      }
    },
    "scriptMappings": {
      "type": "object",
      "description": "Legacy script name mappings and purposes",
      "properties": {
        "names": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "purposes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
